# ============================================================================
# Todo-App-Crud — Environment Variables
# ============================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
# NEVER commit .env to version control.
#
# This repo has two stacks:
#   - Python FastAPI backend  (reads BACKEND_* + CORS)
#   - Vite + TypeScript frontend (reads VITE_*)
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED — App will not start without these
# ----------------------------------------------------------------------------

# Public URL the browser uses to call the FastAPI backend.
# In dev this is the local uvicorn server.
VITE_API_BASE_URL=http://localhost:8000

# Comma-separated list of origins the FastAPI server will accept (CORS).
# Must include the Vite dev server origin.
BACKEND_CORS_ORIGINS=http://localhost:5173

# ----------------------------------------------------------------------------
# OPTIONAL — Defaults shown
# ----------------------------------------------------------------------------

# FastAPI / uvicorn bind address
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Logging
LOG_LEVEL=info
